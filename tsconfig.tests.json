{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node"],
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/features/critical-flows/**/*.ts",
    "src/features/early-access/**/*.ts",
    "src/features/ambassadors/**/*.ts",
    "src/features/auth/landing-content.ts",
    "tests/**/*.ts"
  ]
}
