{
  "name": "guatemalarewards",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "native:sync": "npm run build && cap sync",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:build:debug": "cd android && gradlew.bat assembleDebug",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "test": "tsc -p tsconfig.tests.json && node .tmp-tests/tests/run-tests.js",
    "test:unit": "vitest run src",
    "test:e2e": "node scripts/run-playwright-local.mjs",
    "test:playwright": "node scripts/run-playwright-local.mjs",
    "test:e2e:workflows": "node scripts/run-playwright-local.mjs --workers=1",
    "test:referrals": "node scripts/run-playwright-local.mjs tests/e2e/referrals.spec.ts",
    "test:onboarding": "node scripts/run-playwright-local.mjs tests/e2e/onboarding.spec.ts",
    "test:gift-cards": "node scripts/run-playwright-local.mjs tests/e2e/gift-cards.spec.ts",
    "test:rewards": "node scripts/run-playwright-local.mjs tests/e2e/rewards-redemption.spec.ts",
    "test:agreements": "node scripts/run-playwright-local.mjs tests/e2e/agreements.spec.ts",
    "test:guide": "node scripts/run-guide-playwright.mjs",
    "test:responsive": "node scripts/audit-responsive.mjs",
    "test:load": "node scripts/run-playwright-local.mjs tests/e2e/load.spec.ts",
    "test:launch": "node scripts/run-playwright-local.mjs tests/e2e/launch-checklist.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.8.0",
    "nodemailer": "^9.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "supabase": "^2.93.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
  }
}
