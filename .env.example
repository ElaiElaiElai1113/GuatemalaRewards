# Supabase Configuration
# Copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_PUBLIC_SITE_URL=https://guatemalarewards.com
# Keep false in production. This only enables simulated membership actions for QA/demo environments.
VITE_ENABLE_DEMO_BILLING=false

# Server-only Hostinger SMTP configuration for Vercel API routes.
# Do not prefix these with VITE_ and do not commit real passwords.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@guatemalarewards.com
SMTP_PASS=replace-with-rotated-mailbox-password
SMTP_FROM=Guatemala Rewards <info@guatemalarewards.com>
