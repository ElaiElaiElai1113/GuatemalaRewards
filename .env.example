# Supabase Configuration
# Copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_PUBLIC_SITE_URL=https://medellinrewards.com

# Server-only Hostinger SMTP configuration for Vercel API routes.
# Do not prefix these with VITE_ and do not commit real passwords.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@medellinrewards.com
SMTP_PASS=replace-with-rotated-mailbox-password
SMTP_FROM=Medellin Rewards <info@medellinrewards.com>
